{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Unity Project Schema",
  "type": "object",
  "required": ["id","title","platform"],
  "properties": {
    "id": {"type":"string"},
    "title": {"type":"string"},
    "platform": {"type":"string","const":"unity"},
    "author": {"type":"string"},
    "description": {"type":"string"},
    "tags": {"type":"array","items":{"type":"string"}},
    "objects": {
      "type":"array",
      "items": {
        "type":"object",
        "properties": {
          "name": {"type":"string"},
          "components": {
            "type":"array",
            "items": {"type":"object","properties":{"type":{"type":"string"},"code":{"type":"string"}}}
          }
        }
      }
    },
    "metadata": {"type":"object","properties":{"language":{"type":"string"},"source_image":{"type":"string"}}}
  }
}

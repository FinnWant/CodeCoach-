{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PixelPad Project Schema",
  "type": "object",
  "required": ["id","title","platform"],
  "properties": {
    "id": {"type":"string"},
    "title": {"type":"string"},
    "platform": {"type":"string","const":"pixelpad"},
    "author": {"type":"string"},
    "description": {"type":"string"},
    "tags": {"type":"array","items":{"type":"string"}},
    "classes": {
      "type":"array",
      "items": {
        "type":"object",
        "properties": {
          "name": {"type":"string"},
          "type": {"type":"string"},
          "methods": {
            "type":"array",
            "items": {"type":"object","properties":{"name":{"type":"string"},"code":{"type":"string"}}}
          }
        }
      }
    },
    "assets": {
      "type":"object",
      "properties": {"sprites":{"type":"array","items":{"type":"string"}}}
    },
    "metadata": {"type":"object","properties":{"language":{"type":"string"},"source_image":{"type":"string"}}}
  }
}
